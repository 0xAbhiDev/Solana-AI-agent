{
  "name": "ai-agent",
  "private": true,
  "packageManager": "npm@11.12.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "prisma": "prisma --config prisma.config.ts",
    "prisma:db:push": "prisma --config prisma.config.ts db push"
  },
  "devDependencies": {
    "dotenv": "^17.4.0",
    "prettier": "^3.7.4",
    "turbo": "^2.9.3",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },

  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@prisma/adapter-pg": "7.6.0",
    "@prisma/client": "^7.6.0",
    "@solana/spl-token": "^0.4.14",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "react-hook-form": "^7.72.0",
    "zod": "^4.3.6"
  }
}
